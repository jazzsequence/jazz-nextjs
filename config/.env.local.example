# WordPress REST API Configuration
WORDPRESS_API_URL=https://jazzsequence.com/wp-json/wp/v2

# Site URL (varies by environment)
# Dev: https://dev-jazz-nextjs15.pantheonsite.io
# Test: https://test-jazz-nextjs15.pantheonsite.io
# Live: https://live-jazz-nextjs15.pantheonsite.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# On-demand Revalidation Secret
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=your-secret-key-here

# Optional: WordPress Site URL (for media, links, etc.)
NEXT_PUBLIC_WP_SITE_URL=https://jazzsequence.com
