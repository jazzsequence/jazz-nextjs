{
  "name": "jazz-nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jazzsequence/jazz-nextjs.git"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15.4",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "clean": "rm -rf .next",
    "build": "npm run clean && next build && npm run copy-standalone",
    "copy-standalone": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "start:test": "node scripts/test-standalone.js",
    "lint": "eslint .",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config config/playwright.config.ts",
    "test:e2e:standalone": "BASE_URL=http://localhost:3000 npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "revalidate": "bash scripts/revalidate.sh"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/victor-mono": "^5.2.8",
    "@pantheon-systems/nextjs-cache-handler": "^0.6.0",
    "@storybook/test": "^8.6.15",
    "@testing-library/dom": "^10.4.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html-react-parser": "^5.2.17",
    "isomorphic-dompurify": "^3.0.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "typescript": "^5",
    "zod": "3.24"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.2",
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/nextjs-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.7",
    "eslint-plugin-storybook": "^10.3.1",
    "happy-dom": "^20.7.0",
    "msw": "^2.12.10",
    "pantheon-api-helper": "github:jazzsequence/pantheon-api-helper",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "storybook": "^10.3.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  }
}
