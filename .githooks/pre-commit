#!/bin/bash
# Pre-commit enforcement: Basic checks before commit allowed

set -e

echo "ūüĒć Pre-Commit Validation"
echo "=============================="
echo ""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check 1: Reviewer agent validation (can be bypassed for user commits)
echo "1ÔłŹ‚É£  Checking reviewer agent approval..."

# Allow user to bypass reviewer requirement with USER_COMMIT=1
if [ "$USER_COMMIT" = "1" ]; then
    echo -e "${YELLOW}‚ö†ÔłŹ  User commit bypass enabled${NC}"
    echo "   Skipping reviewer agent check (user-initiated commit)"
elif [ -f reviewer-approved ]; then
    APPROVAL_TIME=$(cat reviewer-approved)
    CURRENT_TIME=$(date +%s)
    TIME_DIFF=$((CURRENT_TIME - APPROVAL_TIME))

    # Approval valid for 5 minutes
    if [ $TIME_DIFF -lt 300 ]; then
        echo -e "${GREEN}‚úÖ Reviewer agent approved (${TIME_DIFF}s ago)${NC}"
        rm reviewer-approved  # Clear approval after use
    else
        echo -e "${RED}‚ĚĆ BLOCKED: Reviewer approval expired (${TIME_DIFF}s old)${NC}"
        echo "   Spawn reviewer agent again and get fresh approval"
        echo "   OR use: USER_COMMIT=1 git commit (for your own changes)"
        exit 1
    fi
else
    echo -e "${RED}‚ĚĆ BLOCKED: No reviewer agent approval found${NC}"
    echo "   For AI-generated changes: Spawn reviewer agent and get APPROVE"
    echo "   For your own changes: Use USER_COMMIT=1 git commit -m \"message\""
    exit 1
fi
echo ""

# Check 2: Run all tests (unit + E2E)
echo "2ÔłŹ‚É£  Running tests..."
echo ""

# Unit tests
echo "   Running unit tests..."
if ! npm test -- --run --reporter=dot 2>&1 | tail -5; then
    echo -e "${RED}‚ĚĆ BLOCKED: Unit tests failed${NC}"
    echo "   Fix test failures before committing"
    exit 1
fi
echo -e "${GREEN}‚úÖ Unit tests passed${NC}"

# Linter
echo "   Running linter..."
if ! npm run lint 2>&1 | grep -E "(error|warning|‚úĒ)" | tail -3; then
    echo -e "${RED}‚ĚĆ BLOCKED: Linter failed${NC}"
    echo "   Fix linting errors before committing"
    exit 1
fi
echo -e "${GREEN}‚úÖ Linter passed${NC}"

# Build validation
echo "   Running build..."
if ! npm run build > /tmp/build-log.txt 2>&1; then
    echo -e "${RED}‚ĚĆ BLOCKED: Build failed${NC}"
    tail -20 /tmp/build-log.txt
    exit 1
fi
echo -e "${GREEN}‚úÖ Build successful${NC}"

# E2E tests (CRITICAL: catches routing conflicts and runtime errors)
echo "   Running E2E tests..."
if ! npm run test:e2e 2>&1 | tail -10; then
    echo -e "${RED}‚ĚĆ BLOCKED: E2E tests failed${NC}"
    echo "   E2E tests catch routing conflicts and runtime errors"
    echo "   Fix failures before committing"
    exit 1
fi
echo -e "${GREEN}‚úÖ E2E tests passed${NC}"
echo ""

# Check 3: No secrets
echo "3ÔłŹ‚É£  Checking for secrets..."
for file in $(git diff --cached --name-only); do
    if [[ "$file" == ".env" ]] || [[ "$file" == *".env."* ]] || [[ "$file" == *"credentials"* ]]; then
        echo -e "${RED}‚ĚĆ BLOCKED: Attempting to commit secrets: $file${NC}"
        exit 1
    fi
done
echo -e "${GREEN}‚úÖ No secrets${NC}"
echo ""

# Check 4: Reviewer agent consulted (enforced by approval flag check in step 1)
if [ "$USER_COMMIT" != "1" ]; then
    echo "4ÔłŹ‚É£  Reviewer oversight check..."
    echo -e "${YELLOW}‚ö†ÔłŹ  MANDATORY: Reviewer agent must approve before every commit.${NC}"
    echo "   1. Spawn reviewer agent with Agent tool"
    echo "   2. Get APPROVE decision from agent"
    echo "   3. Main agent writes approval flag, then commit within 5 minutes"
    echo ""
else
    echo "4ÔłŹ‚É£  Skipping reviewer oversight (user commit)"
    echo ""
fi

echo "=============================="
echo -e "${GREEN}‚úÖ COMMIT ALLOWED${NC}"
echo ""
exit 0
