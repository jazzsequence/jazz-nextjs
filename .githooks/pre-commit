#!/bin/bash
# TDD Compliance Pre-Commit Hook
# Blocks commits that violate TDD rules

set -e

echo "🔍 TDD Pre-Commit Validation"
echo "=============================="
echo ""

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

FAILED=0

# Check 1: Run tests
echo "1️⃣  Running tests..."
if npm test -- --run > /dev/null 2>&1; then
    echo -e "${GREEN}✅ All tests pass${NC}"
else
    echo -e "${RED}❌ BLOCKED: Tests failing${NC}"
    echo "   Fix failing tests before committing"
    exit 1
fi
echo ""

# Check 2: Lint
echo "2️⃣  Running linter..."
if npm run lint > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Lint clean${NC}"
else
    echo -e "${RED}❌ BLOCKED: Lint errors${NC}"
    echo "   Fix lint errors before committing"
    exit 1
fi
echo ""

# Check 3: No secrets
echo "3️⃣  Checking for secrets..."
for file in $(git diff --cached --name-only); do
    if [[ "$file" == ".env" ]] || [[ "$file" == *".env."* ]] || [[ "$file" == *"credentials"* ]]; then
        echo -e "${RED}❌ BLOCKED: Attempting to commit secrets: $file${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ No secrets${NC}"
echo ""

# Check 4: File organization
echo "4️⃣  Checking file organization..."
for file in $(git diff --cached --name-only | grep -E "\.(ts|tsx)$"); do
    if [[ "$file" == *.test.* ]] || [[ "$file" == *.spec.* ]]; then
        if [[ ! "$file" == tests/* ]] && [[ ! "$file" == *".e2e/"* ]]; then
            echo -e "${RED}❌ BLOCKED: Test file in wrong location: $file${NC}"
            echo "   Tests must be in /tests directory"
            exit 1
        fi
    elif [[ "$file" == src/* ]]; then
        if [[ "$file" == *.test.* ]] || [[ "$file" == *.spec.* ]]; then
            echo -e "${RED}❌ BLOCKED: Test file in /src: $file${NC}"
            exit 1
        fi
    fi
done
echo -e "${GREEN}✅ File organization correct${NC}"
echo ""

echo "=============================="
echo -e "${GREEN}✅ COMMIT ALLOWED${NC}"
echo ""
exit 0
