#!/bin/bash
# Pre-commit enforcement: Basic checks before commit allowed

set -e

echo "🔍 Pre-Commit Validation"
echo "=============================="
echo ""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check 1: Reviewer agent validation (can be bypassed for user commits)
echo "1️⃣  Checking reviewer agent approval..."

# Allow user to bypass reviewer requirement with USER_COMMIT=1
if [ "$USER_COMMIT" = "1" ]; then
    echo -e "${YELLOW}⚠️  User commit bypass enabled${NC}"
    echo "   Skipping reviewer agent check (user-initiated commit)"
elif [ -f reviewer-approved ]; then
    APPROVAL_TIME=$(cat reviewer-approved)
    CURRENT_TIME=$(date +%s)
    TIME_DIFF=$((CURRENT_TIME - APPROVAL_TIME))

    # Approval valid for 5 minutes
    if [ $TIME_DIFF -lt 300 ]; then
        echo -e "${GREEN}✅ Reviewer agent approved (${TIME_DIFF}s ago)${NC}"
        rm reviewer-approved  # Clear approval after use
    else
        echo -e "${RED}❌ BLOCKED: Reviewer approval expired (${TIME_DIFF}s old)${NC}"
        echo "   Spawn reviewer agent again and get fresh approval"
        exit 1
    fi
else
    echo -e "${RED}❌ BLOCKED: No reviewer agent approval found${NC}"
    echo "   For AI-generated changes: Spawn reviewer agent and get APPROVE"
    echo "   For your own changes: Use USER_COMMIT=1 git commit -m \"message\""
    exit 1
fi
echo ""

# Check 2: Commit size (AI commits only)
if [ "$USER_COMMIT" != "1" ]; then
    echo "2️⃣  Checking commit size..."
    # package-lock.json is machine-generated and always large on dependency changes —
    # exclude it from both the file count and insertion count.
    STAGED_FILE_COUNT=$(git diff --cached --name-only | grep -v '^package-lock\.json$' | wc -l | tr -d ' ')
    STAGED_INSERTIONS=$(git diff --cached --stat -- ':!package-lock.json' 2>/dev/null | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo 0)

    if [ "$STAGED_FILE_COUNT" -gt 5 ]; then
        echo -e "${RED}❌ BLOCKED: Commit too large — $STAGED_FILE_COUNT files staged (max 5 for AI commits)${NC}"
        echo "   Split into smaller, atomic commits:"
        git diff --cached --name-only | grep -v '^package-lock\.json$' | sed 's/^/     /'
        exit 1
    fi

    if [ "$STAGED_INSERTIONS" -gt 500 ]; then
        echo -e "${RED}❌ BLOCKED: Commit too large — ~$STAGED_INSERTIONS lines added (max 500 for AI commits)${NC}"
        echo "   Split into smaller, atomic commits."
        exit 1
    fi

    echo -e "${GREEN}✅ Commit size OK ($STAGED_FILE_COUNT files, ~$STAGED_INSERTIONS insertions)${NC}"
    echo ""
fi

# Check 3: Run all tests (unit + E2E) — skip only for .md and .txt changes
# Blocklist: only .md and .txt are explicitly skipped.
# Every other file type (yaml, json, ts, css, etc.) triggers the full suite.
# Unknown/new extensions default to running tests — safe by design.
NON_TEXT_FILES=$(git diff --cached --name-only | grep -v '^package-lock\.json$' | grep -Ev '\.(md|txt)$' | wc -l | tr -d ' ')

echo "3️⃣  Running tests..."
echo ""

if [ "$NON_TEXT_FILES" -eq 0 ]; then
    echo "   ℹ️  Markdown/text-only changes — skipping test suite"
    echo -e "${GREEN}✅ Tests skipped (no source code changed)${NC}"
    echo ""
else

# Unit tests
echo "   Running unit tests..."
if ! npm test -- --run --reporter=dot 2>&1 | tail -5; then
    echo -e "${RED}❌ BLOCKED: Unit tests failed${NC}"
    echo "   Fix test failures before committing"
    exit 1
fi
echo -e "${GREEN}✅ Unit tests passed${NC}"

# Linter
echo "   Running linter..."
if ! npm run lint 2>&1 | grep -E "(error|warning|✔)" | tail -3; then
    echo -e "${RED}❌ BLOCKED: Linter failed${NC}"
    echo "   Fix linting errors before committing"
    exit 1
fi
echo -e "${GREEN}✅ Linter passed${NC}"

# Build validation
echo "   Running build..."
if ! npm run build > /tmp/build-log.txt 2>&1; then
    echo -e "${RED}❌ BLOCKED: Build failed${NC}"
    tail -20 /tmp/build-log.txt
    exit 1
fi
echo -e "${GREEN}✅ Build successful${NC}"

# E2E tests (CRITICAL: catches routing conflicts and runtime errors)
echo "   Running E2E tests..."
if ! npm run test:e2e; then
    echo -e "${RED}❌ BLOCKED: E2E tests failed${NC}"
    echo "   E2E tests catch routing conflicts and runtime errors"
    echo "   Fix failures before committing"
    exit 1
fi
echo -e "${GREEN}✅ E2E tests passed${NC}"
echo ""
fi  # end: STAGED_CODE_FILES > 0

# Check 4: No secrets
echo "4️⃣  Checking for secrets..."
for file in $(git diff --cached --name-only); do
    if [[ "$file" == ".env" ]] || [[ "$file" == *".env."* ]] || [[ "$file" == *"credentials"* ]]; then
        echo -e "${RED}❌ BLOCKED: Attempting to commit secrets: $file${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ No secrets${NC}"
echo ""

# Check 5: Reviewer agent consulted (enforced by approval flag check in step 1)
if [ "$USER_COMMIT" != "1" ]; then
    echo "5️⃣  Reviewer oversight check..."
    echo -e "${YELLOW}⚠️  MANDATORY: Reviewer agent must approve before every commit.${NC}"
    echo "   1. Spawn reviewer agent with Agent tool"
    echo "   2. Get APPROVE decision from agent"
    echo "   3. Main agent writes approval flag, then commit within 5 minutes"
    echo ""
else
    echo "5️⃣  Skipping reviewer oversight (user commit)"
    echo ""
fi

echo "=============================="
echo -e "${GREEN}✅ COMMIT ALLOWED${NC}"
echo ""
exit 0
